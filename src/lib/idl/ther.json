            ],
            "type": "pubkey"
          },
          {
            "name": "platform_wallet",
            "docs": [
              "Receives 0.005 SOL per swap and 0.05 SOL per vault creation"
            ],
            "type": "pubkey"
          },
          {
            "name": "creation_fee",
            "docs": [
              "Vault creation fee in lamports (default: 50_000_000 = 0.05 SOL)"
            ],
            "type": "u64"
          },
          {
            "name": "swap_fee",
            "docs": [
              "Total swap fee in lamports (default: 7_000_000 = 0.007 SOL)"
            ],
            "type": "u64"
          },
          {
            "name": "platform_fee",
            "docs": [
              "Platform portion of swap fee in lamports (default: 5_000_000 = 0.005 SOL)"
            ],
            "type": "u64"
